generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Entidade central do TRACEFLOW.
// TODO: Revisar os campos durante a implementacao de RF01, RF02, RF21 e RF22.
model Project {
  id                       Int       @id @default(autoincrement())
  name                     String
  description              String?
  responsibleTeam          String
  githubOwner              String?
  githubRepo               String?
  githubUrl                String?
  githubRepositoryId       String?
  githubRepositoryName     String?
  githubRepositoryFullName String?
  githubRepositoryUrl      String?
  githubDefaultBranch      String?
  githubIsPrivate          Boolean?
  githubIntegratedAt       DateTime?
  githubAutoSyncEnabled    Boolean   @default(false)
  githubLastSyncAt         DateTime?
  githubSyncStatus         String?
  githubLastSyncError      String?
  githubLastSyncAttemptAt  DateTime?
  status                   String    @default("ATIVO")
  accessCode               String?   @unique
  inviteLink               String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  requirements  Requirement[]
  tasks         Task[]
  members       ProjectMember[]
  taskMovements TaskMovement[]
  artifacts     GithubArtifact[]
  traceLinks    TraceLink[]
  commits       Commit[]
  pullRequests  PullRequest[]
  issues        Issue[]

  @@unique([githubRepositoryId])
  @@unique([githubRepositoryFullName])
}

// Requisito funcional ou necessidade cadastrada no projeto.
// TODO: Implementar futuramente a cadeia Requirement -> Task -> GithubArtifact.
model Requirement {
  id          Int      @id @default(autoincrement())
  projectId   Int
  title       String
  description String?
  type        String   @default("FUNCIONAL")
  status      String   @default("PENDENTE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
  tasks   Task[]
}

// Unidade de trabalho e elo entre planejamento e implementacao.
model Task {
  id              Int       @id @default(autoincrement())
  projectId       Int
  requirementId   Int?
  title           String
  description     String?
  priority        String    @default("MEDIA")
  responsible     String?
  status          String    @default("A_FAZER")
  deadline        DateTime?
  estimatedEffort Int?
  actualEffort    Int?
  pullRequestId   Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project     Project        @relation(fields: [projectId], references: [id])
  requirement Requirement?   @relation(fields: [requirementId], references: [id])
  pullRequest PullRequest?   @relation(fields: [pullRequestId], references: [id], onDelete: SetNull)
  movements   TaskMovement[]
  commitLinks TaskCommit[]
  issueLinks  TaskIssue[]

  @@index([pullRequestId])
}

// Vinculo de rastreabilidade entre tarefas e commits importados do GitHub.
model TaskCommit {
  id        Int      @id @default(autoincrement())
  taskId    Int
  commitId  Int
  createdAt DateTime @default(now())

  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  commit Commit @relation(fields: [commitId], references: [id], onDelete: Cascade)

  @@unique([taskId, commitId])
  @@index([taskId])
  @@index([commitId])
}

// Vinculo de rastreabilidade entre tarefas e issues importadas do GitHub.
model TaskIssue {
  id        Int      @id @default(autoincrement())
  taskId    Int
  issueId   Int
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([taskId, issueId])
  @@index([taskId])
  @@index([issueId])
}

// Membro interno de um projeto no TRACEFLOW.
model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int
  name      String
  email     String?
  role      String   @default("MEMBRO")
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project   Project        @relation(fields: [projectId], references: [id])
  movements TaskMovement[]

  @@unique([projectId, email])
  @@index([projectId])
}

// Historico de movimentacoes do quadro Kanban do RF08.
model TaskMovement {
  id              Int      @id @default(autoincrement())
  projectId       Int
  taskId          Int
  fromStatus      String
  toStatus        String
  movedBy         String
  projectMemberId Int?
  movedAt         DateTime @default(now())
  sprintId        Int?
  createdAt       DateTime @default(now())

  project       Project        @relation(fields: [projectId], references: [id])
  task          Task           @relation(fields: [taskId], references: [id])
  projectMember ProjectMember? @relation(fields: [projectMemberId], references: [id])

  @@index([projectId])
  @@index([taskId])
  @@index([projectMemberId])
  @@index([movedAt])
}

// Generalizacao de Commit, PullRequest e Issue no MVP.
// TODO: Restringir type a COMMIT, PULL_REQUEST ou ISSUE na camada de servico.
model GithubArtifact {
  id              Int       @id @default(autoincrement())
  projectId       Int
  type            String
  externalId      String?
  sha             String?
  title           String?
  description     String?
  author          String?
  status          String?
  branch          String?
  url             String?
  createdAtGithub DateTime?
  closedAtGithub  DateTime?
  importedAt      DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, type, externalId])
}

// Vinculo manual de rastreabilidade entre os elementos do MVP.
// TODO: Implementar Requirement -> Task e Task -> GithubArtifact.
model TraceLink {
  id         Int      @id @default(autoincrement())
  projectId  Int
  sourceType String
  sourceId   Int
  targetType String
  targetId   Int
  linkType   String   @default("RELATED_TO")
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

// Commit importado do repositorio GitHub vinculado ao projeto.
// TODO: Relacionar commits a tarefas quando o fluxo de rastreabilidade evoluir.
model Commit {
  id             Int       @id @default(autoincrement())
  hash           String
  message        String?   @db.Text
  authorName     String?
  authorEmail    String?
  authorUsername String?
  date           DateTime?
  branch         String?
  githubUrl      String?
  projectId      Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskLinks TaskCommit[]

  @@unique([projectId, hash])
}

// Pull Request importado do repositorio GitHub vinculado ao projeto.
// TODO: Relacionar pull requests a tarefas quando a rastreabilidade tecnica evoluir.
model PullRequest {
  id              Int       @id @default(autoincrement())
  githubId        String
  number          Int
  title           String
  description     String?   @db.Text
  state           String?
  authorUsername  String?
  sourceBranch    String?
  targetBranch    String?
  githubUrl       String?
  createdAtGithub DateTime?
  updatedAtGithub DateTime?
  closedAtGithub  DateTime?
  mergedAtGithub  DateTime?
  projectId       Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, githubId])
  @@unique([projectId, number])
}

// Issue importada do repositorio GitHub vinculado ao projeto.
model Issue {
  id               Int       @id @default(autoincrement())
  githubId         String
  number           Int
  title            String
  description      String?   @db.Text
  state            String?
  authorUsername   String?
  assigneeUsername String?
  labels           Json?
  milestone        String?
  githubUrl        String?
  createdAtGithub  DateTime?
  updatedAtGithub  DateTime?
  closedAtGithub   DateTime?
  projectId        Int
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskLinks TaskIssue[]

  @@unique([projectId, githubId])
  @@unique([projectId, number])
}

// TODO: Avaliar em evolucoes futuras User, Sprint, TestCase, Defect, Alert,
// Notification, Report, Indicator e Comment. Essas entidades ficam fora do MVP.
